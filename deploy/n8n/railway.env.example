# ==============================================================
# Railway Environment Variables — n8n Service
# Copy these into: Railway → n8n service → Variables
# ==============================================================

# ── REQUIRED ───────────────────────────────────────────────────
# The public Railway URL of THIS n8n service (auto-set after first deploy)
# Format: https://<your-n8n-service>.up.railway.app
N8N_HOST=your-n8n-service.up.railway.app
WEBHOOK_URL=https://your-n8n-service.up.railway.app/

# Encryption key for stored credentials — generate a random string
# python -c "import secrets; print(secrets.token_hex(32))"
N8N_ENCRYPTION_KEY=PASTE_GENERATED_KEY_HERE

# ── Authentication ─────────────────────────────────────────────
# Basic auth to protect the n8n editor UI
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHOOSE_A_STRONG_PASSWORD

# ── Database (PostgreSQL) ──────────────────────────────────────
# Create a NEW Railway PostgreSQL service for n8n
# Railway gives you DATABASE_URL — set it here
DB_TYPE=postgresdb
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_HOST=your-postgres-host.railway.internal
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=YOUR_POSTGRES_PASSWORD
DB_POSTGRESDB_SCHEMA=public

# Alternative: set DATABASE_URL directly (Railway injects this if you
# link a PostgreSQL service)
# DATABASE_URL=postgresql://user:password@host:5432/n8n

# ── Execution storage ──────────────────────────────────────────
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_PROGRESS=false
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true

# ── Newsconseen integration ────────────────────────────────────
# Webhook secret shared with python_layer (N8N_WEBHOOK_SECRET)
# Set the same value in python_layer's Railway variables
N8N_WEBHOOK_SECRET=CHOOSE_A_SHARED_SECRET

# Newsconseen python_layer URL (for n8n → python_layer HTTP nodes)
NEWSCONSEEN_API_URL=https://newsconseenwebapp-production.up.railway.app

# ── Embedding ─────────────────────────────────────────────────
# Allow Newsconseen frontend to embed n8n in an iframe
N8N_IFRAME_ALLOW_ORIGIN=https://newsconseenwebapp-production.up.railway.app

# ── General ───────────────────────────────────────────────────
GENERIC_TIMEZONE=Africa/Nairobi
N8N_LOG_LEVEL=info
N8N_PROTOCOL=https
N8N_PORT=5678

# Port (Railway sets this automatically — do not override)
# PORT=5678
