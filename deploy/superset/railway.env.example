# ==============================================================
# Railway Environment Variables — Superset Service
# Copy these into: Railway → superset service → Variables
# ==============================================================

# ── REQUIRED ───────────────────────────────────────────────────
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(42))"
SUPERSET_SECRET_KEY=PASTE_GENERATED_SECRET_KEY_HERE

# Superset's own PostgreSQL (create a NEW Railway PostgreSQL service for this)
# Railway gives you DATABASE_URL automatically — rename it here
SUPERSET_DATABASE_URL=${{Postgres.DATABASE_URL}}

# Admin credentials for first login
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=Cafedenyamata@123
SUPERSET_ADMIN_EMAIL=anewsconseen@gmail.com

# ── Newsconseen integration ────────────────────────────────────
# The python_layer DATABASE_URL — Superset connects to analytics.* tables
NEWSCONSEEN_DB_URL=postgresql://user:password@host:5432/railway

# Your Newsconseen frontend URL (for CORS + iframe allowlist)
NEWSCONSEEN_FRONTEND_URL=https://newsconseenwebapp-production.up.railway.app

# ── OPTIONAL ───────────────────────────────────────────────────
# Redis for caching (add a Railway Redis service)
REDIS_URL=redis://default:password@redis.railway.internal:6379

# SMTP for email alerts
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=YOUR_SENDGRID_KEY
SMTP_FROM=alerts@newsconseen.com

# Port (Railway sets this automatically — do not override)
# PORT=8088
