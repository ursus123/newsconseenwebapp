# ==============================================================
# Railway Environment Variables — Airbyte Service
# ==============================================================
# NOTE: Airbyte is best deployed via Railway's one-click template.
# Railway → New → Template → search "Airbyte"
#
# If deploying manually from the Airbyte Docker Compose, these are
# the key variables to configure.
# ==============================================================

# ── Core ───────────────────────────────────────────────────────
# Airbyte generates these automatically on first boot.
# Only override if you need to restore from a backup.
BASIC_AUTH_USERNAME=airbyte
BASIC_AUTH_PASSWORD=CHOOSE_A_STRONG_PASSWORD

# ── Database (PostgreSQL) ──────────────────────────────────────
# Airbyte needs its OWN PostgreSQL instance for job state / config.
# Create a NEW Railway PostgreSQL service.
DATABASE_URL=postgresql://user:password@host:5432/airbyte

# ── Newsconseen integration ────────────────────────────────────
# Source: Base44 REST connector → pull entities from Base44 API
# Destination: Newsconseen PostgreSQL (python_layer DATABASE_URL)
#
# Set these as named connections inside Airbyte UI:
#   Sources    → Add source    → "HTTP Request" or custom connector
#   Destinations → Add destination → PostgreSQL
#
NEWSCONSEEN_DB_URL=postgresql://user:password@host:5432/railway
BASE44_API_KEY=YOUR_BASE44_API_KEY

# ── Port ───────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override.
# Airbyte webapp listens on 8000 by default.
# PORT=8000
