# ============================================================
# NEWSCONSEEN ANALYTICS LAYER — ENVIRONMENT CONFIGURATION
# ============================================================
# This file defines all environment variables required for:
# - FastAPI microservice
# - ETL modules
# - Airflow DAGs
# - Superset analytics
# - Base44 API integration
# ============================================================


# ------------------------------------------------------------
# BASE44 API ENDPOINTS (Operational System)
# ------------------------------------------------------------
# These URLs point to your Base44 auto‑generated backend.
# They are used by ETL modules to extract operational data.

BASE44_TASKS_URL=
BASE44_TRANSACTIONS_URL=
BASE44_SERVICES_URL=
BASE44_ENTERPRISES_URL=
BASE44_PEOPLE_URL=

# Base44 API key for authenticated requests
BASE44_API_KEY=


# ------------------------------------------------------------
# ANALYTICS DATABASE (PostgreSQL recommended)
# ------------------------------------------------------------
# This is where ETL results are loaded by Airflow and FastAPI.
# Superset connects to the same database to build dashboards.

# Example:
# postgresql://username:password@hostname:5432/newsconseen
DATABASE_URL=


# ------------------------------------------------------------
# FASTAPI SETTINGS
# ------------------------------------------------------------
# Optional: override host/port if deploying behind a proxy.

API_HOST=0.0.0.0
API_PORT=8000


# ------------------------------------------------------------
# AIRFLOW SETTINGS (Optional but recommended)
# ------------------------------------------------------------
# These allow Airflow to import your Python layer cleanly.

PYTHON_LAYER_PATH=/opt/airflow/python_layer


# ------------------------------------------------------------
# LOGGING / DEBUG
# ------------------------------------------------------------
# Set to "true" for verbose logs during development.

DEBUG=false
