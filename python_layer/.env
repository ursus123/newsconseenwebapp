# ==============================================================
# NEWSCONSEEN — python_layer Environment Variables
# Railway + PostgreSQL Setup
# ==============================================================
# HOW TO USE:
#   1. Copy this file and rename it to .env
#   2. Fill in every value marked as REQUIRED
#   3. Values marked OPTIONAL can be left blank to start
#   4. In Railway: paste each variable into the Railway
#      Environment Variables panel (not as a file)
# ==============================================================


# ==============================================================
# SECTION 1 — BASE44 AUTHENTICATION
# Required for ALL ETL pulls. Without this nothing works.
# ==============================================================

# Your Base44 API key.
# Where to find it: Base44 app → Settings → API → API Key
# REQUIRED
BASE44_API_KEY=your_base44_api_key_here


# ==============================================================
# SECTION 2 — BASE44 ENTITY URLS
# One URL per master entity in Newsconseen.
# Where to find them: Base44 app → Settings → API → Entities
# Each entity has its own endpoint URL.
# All are REQUIRED for full ETL. Comment out any you haven't
# created yet in Base44 — the app will start without them.
# ==============================================================

# MASTER ENTITIES (Core forms — define reality)
BASE44_ENTERPRISES_URL=https://app.base44.com/api/apps/YOUR_APP_ID/entities/enterprises
BASE44_PEOPLE_URL=https://app.base44.com/api/apps/YOUR_APP_ID/entities/people
BASE44_PRODUCTS_URL=https://app.base44.com/api/apps/YOUR_APP_ID/entities/products
BASE44_SERVICES_URL=https://app.base44.com/api/apps/YOUR_APP_ID/entities/services
BASE44_ADDRESSES_URL=https://app.base44.com/api/apps/YOUR_APP_ID/entities/addresses

# OPERATIONAL ENTITIES (Transactions and Tasks)
BASE44_TRANSACTIONS_URL=https://app.base44.com/api/apps/YOUR_APP_ID/entities/transactions
BASE44_TASKS_URL=https://app.base44.com/api/apps/YOUR_APP_ID/entities/tasks

# RELATIONSHIP ENTITY (Person↔Enterprise, Item↔Enterprise, Item↔Person)
# Critical for cross-entity dashboards. Confirm this entity exists in Base44.
BASE44_RELATIONSHIPS_URL=https://app.base44.com/api/apps/YOUR_APP_ID/entities/relationships


# ==============================================================
# SECTION 3 — RAILWAY POSTGRESQL
# Your analytics store. All ETL summaries land here.
# Where to find it: Railway project → PostgreSQL service
#                   → Connect → Connection String
# Copy the full string exactly as Railway shows it.
# REQUIRED
# ==============================================================

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_RAILWAY_HOST:5432/railway

# Note: Railway rotates credentials occasionally.
# If ETL stops working, check this URL is still valid in Railway.


# ==============================================================
# SECTION 4 — CRON PROTECTION
# Protects the POST /cron/etl-all endpoint from unauthorized
# calls. Railway calls this on a schedule to refresh ETL data.
# Make up any random string — treat it like a password.
# REQUIRED (leave blank only if you never use the cron endpoint)
# ==============================================================

CRON_SECRET=newsconseen123


# ==============================================================
# SECTION 5 — GEOSPATIAL (Nominatim / OpenStreetMap)
# Used by etl/geospatial.py to geocode enterprise addresses.
# Nominatim is free but requires a valid contact email so they
# can reach you if your app causes issues.
# REQUIRED if you want map features to work.
# ==============================================================

# Your contact email — included in Nominatim User-Agent header.
# Nominatim's terms require this. Without it geocoding may be blocked.
NOMINATIM_CONTACT_EMAIL=your_email@example.com


# ==============================================================
# SECTION 6 — OPEN DATA API KEYS
# All optional. The endpoints work without keys using public
# access tiers, but keys unlock higher rate limits.
# ==============================================================

# USDA NASS QuickStats — crop and livestock survey data
# Free key at: https://quickstats.nass.usda.gov/api
# OPTIONAL — endpoints degrade gracefully without it
USDA_NASS_API_KEY=

# US Census Bureau — demographics, business patterns, population
# Free key at: https://api.census.gov/data/key_signup.html
# OPTIONAL — many Census endpoints work without a key
CENSUS_API_KEY=

# Alpha Vantage — stock fundamentals (beyond Yahoo Finance)
# Free key at: https://www.alphavantage.co/support/#api-key
# OPTIONAL — stock quotes still work via Yahoo Finance without this
ALPHA_VANTAGE_KEY=

# FRED (Federal Reserve Economic Data) — macroeconomic indicators
# Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# OPTIONAL — CSV endpoint works without key, JSON needs key
FRED_API_KEY=


# ==============================================================
# SECTION 7 — APP CONFIGURATION
# Controls how the FastAPI app behaves.
# ==============================================================

# Environment label — controls logging verbosity and debug mode.
# Use "development" locally, "production" on Railway.
# OPTIONAL — defaults to "production"
APP_ENV=production

# Allowed CORS origins for the FastAPI middleware.
# In production: replace * with your actual Base44 app URL.
# Example: https://your-app.base44.com
# OPTIONAL — defaults to * (allow all)
CORS_ALLOWED_ORIGINS=*

# How many records to fetch per page from Base44.
# Base44 may have a max page size — check their docs if ETL is slow.
# OPTIONAL — defaults to 500
PAGE_SIZE=500

# Seconds before a Base44 API request times out.
# OPTIONAL — defaults to 30
REQUEST_TIMEOUT=30

# How many times to retry a failed Base44 request before giving up.
# OPTIONAL — defaults to 3
MAX_RETRIES=3


# ==============================================================
# SECTION 8 — ML LAYER (SUSPENDED)
# The ML routes (Prophet, Cox PH, XGBoost) are currently
# suspended while the core entity model is being rebuilt.
# Set to "false" to disable all /ml/* endpoints.
# OPTIONAL — defaults to false
# ==============================================================

ML_ENABLED=false


# ==============================================================
# QUICK CHECKLIST BEFORE DEPLOYING TO RAILWAY
# ==============================================================
# [ ] BASE44_API_KEY is filled in
# [ ] All BASE44_*_URL values point to real Base44 entities
# [ ] DATABASE_URL matches your Railway PostgreSQL connection string
# [ ] CRON_SECRET is set to something random
# [ ] NOMINATIM_CONTACT_EMAIL is a real email address
# [ ] In Railway: all variables are added to Environment Variables
#     panel — Railway does NOT read .env files automatically
# [ ] .env is in .gitignore — NEVER commit this file to GitHub
# ==============================================================
